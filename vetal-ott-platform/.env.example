PORT=3000
AWS_REGION=ap-south-1
S3_BUCKET_NAME=your-bucket-name
S3_MEDIA_PREFIX=movie/
PRESIGNED_URL_EXPIRY=3600

# AWS credentials are NOT set here when running on EC2 — the instance's
# attached IAM role provides credentials automatically. Only set these
# if running locally outside of AWS:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
